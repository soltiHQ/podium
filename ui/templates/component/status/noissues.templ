package status

// NoIssues renders a "no issues" placeholder with an illustration.
templ NoIssues(message string) {
	<div class={ containerClass("py-14") }>
		<div class="opacity-70">
			<img
				src="/static/img/noissues.png"
				alt=""
				aria-hidden="true"
				class="w-47 h-auto select-none pointer-events-none"
			/>
		</div>

		<p class={ messageClass(true) }>
			{ message }
		</p>
	</div>
}
