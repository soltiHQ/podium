package agent

import (
	"github.com/soltiHQ/control-plane/domain/kind"
	"github.com/soltiHQ/control-plane/domain/model"
	"github.com/soltiHQ/control-plane/internal/uikit/routepath"
	"github.com/soltiHQ/control-plane/internal/uikit/timeformat"
	"github.com/soltiHQ/control-plane/internal/uikit/htmx"
	"github.com/soltiHQ/control-plane/ui/templates/component/card"
	"github.com/soltiHQ/control-plane/ui/templates/component/form"
	"github.com/soltiHQ/control-plane/ui/templates/component/list"
	"github.com/soltiHQ/control-plane/ui/templates/component/status"
	"github.com/soltiHQ/control-plane/ui/templates/component/visual"
)

// List renders the paginated agent list with search and cursor-based loading.
templ List(items []*model.Agent, nextCursor string, q string) {
	<div class="space-y-4">
		<div class="flex justify-center mb-10">
			<div class="w-[320px] max-sm:w-full">
				@form.SearchInput(
					"agents-search",
					"q",
					q,
					"Search…",
					routepath.ApiAgents,
					"#agents-results",
				)
			</div>
		</div>

		@Results(items, nextCursor, q)
	</div>
}

// Results is the HTMX-swappable wrapper for the agent cards + pagination sentinel.
// SSE and polling triggers live here (not on the outer loader) so that refreshes
// replace only the results, leaving the search input untouched.
templ Results(items []*model.Agent, nextCursor string, q string) {
	<div
		id="agents-results"
		hx-get={ routepath.ApiAgents }
		hx-trigger={ htmx.Poll(htmx.GetAgentsRefresh(), htmx.AgentUpdate) }
		hx-target="this"
		hx-swap="outerHTML"
		hx-select="#agents-results"
		hx-include="#agents-search"
	>
		<div id="agents-cards" class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
			@Cards(items)
			if nextCursor != "" {
				@list.Sentinel("agents-sentinel", routepath.CursorURL(routepath.ApiAgents, nextCursor, q), "agents-cards")
			}
		</div>
	</div>
}

// Cards renders the grid of agent item cards.
templ Cards(items []*model.Agent) {
	if len(items) == 0 {
		@status.NotFound("No agents found")
	} else {
		for _, a := range items {
			@card.Item(routepath.PageAgentInfoByID(a.ID())) {
				@card.ItemHeader() {
					<div class="flex items-center gap-2.5 min-w-0">
						@agentStatusDot(a.Status())
						@card.ItemTitle() {
							if a.Name() != "" {
								{ a.Name() }
							} else {
								{ a.ID() }
							}
						}
					</div>

					if a.UptimeSeconds() > 0 {
						<span class="text-[11px] text-muted tabular-nums shrink-0">
							{ timeformat.Uptime(a.UptimeSeconds()) }
						</span>
					}
				}

				@card.ItemBody() {
					if a.Name() != "" {
						<div class="text-[11px] font-mono text-muted tracking-wide">
							{ a.ID() }
						</div>
					}

					if a.Endpoint() != "" {
						<div class="text-xs text-muted-strong">
							{ a.Endpoint() }
						</div>
					}

					<div class="flex items-center gap-1.5 flex-wrap">
						if a.Platform() != "" {
							@visual.Badge(a.Platform(), visual.VariantPrimary)
						}
						if a.OS() != "" {
							@visual.Badge(a.OS(), visual.VariantMuted)
						}
						if a.Arch() != "" {
							@visual.Badge(a.Arch(), visual.VariantMuted)
						}
					</div>
				}
			}
		}
	}
}


templ agentStatusDot(s kind.AgentStatus) {
	@visual.StatusDot(agentDotColor(s))
}

