package agent

import (
	"fmt"
	"net/url"
	"strconv"

	proxyv1 "github.com/soltiHQ/control-plane/api/proxy/v1"
	"github.com/soltiHQ/control-plane/internal/uikit/routepath"
	"github.com/soltiHQ/control-plane/internal/uikit/trigger"
	"github.com/soltiHQ/control-plane/ui/templates/component/card"
	"github.com/soltiHQ/control-plane/ui/templates/component/form"
	"github.com/soltiHQ/control-plane/ui/templates/component/status"
	"github.com/soltiHQ/control-plane/ui/templates/component/visual"
)

// Tasks renders the paginated task table for a specific agent.
templ Tasks(agentID string, items []proxyv1.Task, total int, q string, offset int) {
	@card.Card("") {
		@card.CardHeader() {
			<h2 class="text-[11px] uppercase tracking-[0.05em] text-muted select-none">
				Tasks
			</h2>
			<span class="text-[11px] text-muted tabular-nums">
				{ fmt.Sprintf("%d", total) }
			</span>
		}

		@card.CardBody() {
			<div class="mb-4">
				@form.SearchInput(
					"tasks-search",
					"q",
					q,
					"Filter by slot…",
					routepath.ApiAgentTasks(agentID),
					"#tasks-results",
				)
			</div>

			@TaskResults(agentID, items, total, q, offset)
		}
	}
}

// TaskResults is the HTMX-swappable wrapper for task rows + pagination.
// SSE and polling triggers live here (not on the outer panel) so that refreshes
// replace only the results, leaving the search input untouched.
templ TaskResults(agentID string, items []proxyv1.Task, total int, q string, offset int) {
	<div
		id="tasks-results"
		hx-get={ routepath.ApiAgentTasks(agentID) }
		hx-trigger={ trigger.GetAgentTasksRefresh() + ", " + trigger.AgentUpdate + " from:body" }
		hx-target="this"
		hx-swap="outerHTML"
		hx-select="#tasks-results"
		hx-include="#tasks-search"
	>
		<div id="tasks-rows" class="divide-y divide-border -mx-5">
			@TaskRows(items)
			@taskSentinel(agentID, total, q, offset, len(items))
		</div>
	</div>
}

// TaskRows renders table rows for a slice of tasks.
templ TaskRows(items []proxyv1.Task) {
	if len(items) == 0 {
		@status.Empty("No tasks found")
	} else {
		for _, t := range items {
			@taskRow(t)
		}
	}
}

templ taskRow(t proxyv1.Task) {
	<div class="px-5 py-3 space-y-1.5">
		<div class="flex items-center justify-between gap-3">
			<div class="flex items-center gap-2 min-w-0">
				@taskStatusBadge(t.Status)
				<span class="text-sm font-medium text-fg truncate">{ t.Slot }</span>
			</div>

			if t.Attempt > 0 {
				<span class="shrink-0 text-[11px] text-muted tabular-nums">
					#{ fmt.Sprintf("%d", t.Attempt) }
				</span>
			}
		</div>

		<div class="text-[11px] font-mono text-muted tracking-wide truncate">
			{ t.ID }
		</div>

		if t.Error != "" {
			<div class="text-xs text-danger/80 break-words leading-snug">
				{ t.Error }
			</div>
		}
	</div>
}

templ taskStatusBadge(s string) {
	switch s {
		case "running":
			@visual.Badge("running", visual.VariantPrimary) {
				@visual.StatusDot("primary")
			}
		case "succeeded":
			@visual.Badge("succeeded", visual.VariantSuccess)
		case "failed":
			@visual.Badge("failed", visual.VariantDanger)
		case "pending":
			@visual.Badge("pending", visual.VariantMuted)
		case "timeout":
			@visual.Badge("timeout", visual.VariantDanger)
		case "canceled":
			@visual.Badge("canceled", visual.VariantMuted)
		case "exhausted":
			@visual.Badge("exhausted", visual.VariantDanger)
		default:
			@visual.Badge(s, visual.VariantMuted)
	}
}

// taskSentinel renders the infinite-scroll sentinel for offset-based task pagination.
// It replaces itself (outerHTML) with the next page's rows + a new sentinel.
templ taskSentinel(agentID string, total int, q string, offset int, count int) {
	if nextOffset(offset, count) < total {
		<div
			id="tasks-sentinel"
			class="h-6"
			hx-get={ tasksURL(agentID, q, nextOffset(offset, count)) }
			hx-trigger="revealed"
			hx-target="this"
			hx-swap="outerHTML"
			hx-select="#tasks-rows > *"
			hx-sync="#tasks-sentinel:replace"
		></div>
	}
}

func nextOffset(offset int, count int) int {
	return offset + count
}

func tasksURL(agentID string, q string, offset int) string {
	v := url.Values{}
	if q != "" {
		v.Set("q", q)
	}
	if offset > 0 {
		v.Set("offset", strconv.Itoa(offset))
	}
	qs := v.Encode()
	base := routepath.ApiAgentTasks(agentID)
	if qs == "" {
		return base
	}
	return base + "?" + qs
}
