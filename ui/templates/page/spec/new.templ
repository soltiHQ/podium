package spec

import (
	"github.com/soltiHQ/control-plane/internal/uikit/policy"
	"github.com/soltiHQ/control-plane/internal/uikit/routepath"
	compnav "github.com/soltiHQ/control-plane/ui/templates/component/nav"
	"github.com/soltiHQ/control-plane/ui/templates/layout"
	contentSpec "github.com/soltiHQ/control-plane/ui/templates/content/spec"
)

// New renders the full-page spec builder.
templ New(nav policy.Nav) {
	@layout.App("New Spec", "tasks", nav) {
		@compnav.BackLink(routepath.PageSpecs, "Back to Specs")

		@contentSpec.BuilderPage(nil)
	}
}
